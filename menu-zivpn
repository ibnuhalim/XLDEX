#!/bin/bash
# ================================================
# ZIVPN UDP MENU - BASH MURNI (TANPA PYTHON)
# Menggunakan jq untuk manipulasi JSON
# ================================================

export RED='\033[0;31m'
export GREEN='\033[0;32m'
export YELLOW='\033[0;33m'
export CY='\033[0;36m'
export NC='\033[0m'

function garis() { echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; }

DIR="/etc/zivpn"
JSON="$DIR/config.json"
EXPIRED_DB="$DIR/expired.db"

# Pastikan direktori ada
[ ! -d "$DIR" ] && mkdir -p "$DIR"

# Pastikan jq terpasang
if ! command -v jq &> /dev/null; then
    echo -e "${RED}Error: 'jq' tidak ditemukan. Install dengan: apt install jq -y${NC}"
    exit 1
fi

# Inisialisasi file JSON jika belum ada atau kosong
if [ ! -f "$JSON" ] || [ ! -s "$JSON" ]; then
    echo '{"auth": {"config": []}}' > "$JSON"
fi

# Inisialisasi file expired.db
[ ! -f "$EXPIRED_DB" ] && touch "$EXPIRED_DB"

# ==================== FUNGSI MANAJEMEN AKUN ====================

# Menambahkan password ke auth.config (tanpa duplikat)
add_account() {
    local pass="$1"
    [ -z "$pass" ] && return 1
    # Gunakan jq: tambahkan ke array, lalu pastikan unik
    jq --arg pass "$pass" '.auth.config += [$pass] | .auth.config |= unique' "$JSON" > "${JSON}.tmp" && mv "${JSON}.tmp" "$JSON"
    return $?
}

# Menghapus password dari auth.config
del_account() {
    local pass="$1"
    [ -z "$pass" ] && return 1
    jq --arg pass "$pass" '.auth.config -= [$pass]' "$JSON" > "${JSON}.tmp" && mv "${JSON}.tmp" "$JSON"
    return $?
}

# Mendaftar semua password dari auth.config
list_accounts() {
    jq -r '.auth.config[]' "$JSON" 2>/dev/null
}

# ==================== FUNGSI LAINNYA ====================

get_ip_info() {
    local json=$(curl -s "http://ip-api.com/json?fields=status,city,isp")
    if echo "$json" | grep -q '"status":"success"'; then
        city=$(echo "$json" | grep -o '"city":"[^"]*"' | cut -d'"' -f4)
        isp=$(echo "$json" | grep -o '"isp":"[^"]*"' | cut -d'"' -f4)
    else
        city="Unknown"
        isp="Unknown"
    fi
}

get_domain() {
    [ -f /etc/xray/domain ] && cat /etc/xray/domain || curl -s ipv4.icanhazip.com
}

# ==================== MENU ====================

create() {
    clear
    garis
    echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP CREATE°            \E[0m|"
    garis
    read -p "Password   : " pwd
    read -p "Exp (0 untuk unlimited) : " expd
    if [[ ! "$expd" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Exp harus angka!${NC}"
        return
    fi

    # Cek apakah password sudah ada
    if list_accounts | grep -qx "$pwd"; then
        echo -e "${RED}Password sudah terdaftar!${NC}"
        return
    fi

    get_ip_info
    domain=$(get_domain)

    if [ "$expd" -eq 0 ]; then
        exp_date="unlimited"
        exp_show="UNLIMITED"
    else
        exp_date=$(date -d "+${expd} days" +%Y-%m-%d)
        exp_show="$exp_date"
    fi

    add_account "$pwd"
    echo "$pwd|$exp_date" >> "$EXPIRED_DB"
    systemctl restart zivpn >/dev/null 2>&1

    clear
    garis
    echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}PREMIUM ACCOUNT ZIV UDP${NC}"
    echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "Password   : $pwd"
    echo -e "CITY       : $city"
    echo -e "ISP        : $isp"
    echo -e "Domain     : $domain"
    echo -e "Expired On : $exp_show"
    echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━${NC}"
    garis
    echo -e "${GREEN}| \E[44;1;39m      XD STORE            \E[0m|"
    garis
}

delete() {
    clear
    garis
    echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP DELETE°            \E[0m|"
    garis
    read -p "Password : " pwd
    if ! list_accounts | grep -qx "$pwd"; then
        echo -e "${RED}Account tidak ditemukan!${NC}"
        return
    fi
    del_account "$pwd"
    sed -i "/^$pwd|/d" "$EXPIRED_DB"
    systemctl restart zivpn >/dev/null 2>&1
    clear
    garis
    echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP DELETED!°            \E[0m|"
    garis
    echo "PASSWORD: $pwd"
    echo "Delete success!!"
    garis
    echo -e "${GREEN}| \E[44;1;39m      XD STORE            \E[0m|"
    garis
}

renew() {
    clear
    garis
    echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP RENEW°            \E[0m|"
    garis
    read -p "Password : " pwd
    if ! list_accounts | grep -qx "$pwd"; then
        echo -e "${RED}Account tidak ditemukan!${NC}"
        return
    fi
    read -p "New Exp (0 unlimited) : " expd
    if [[ ! "$expd" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Exp harus angka!${NC}"
        return
    fi

    if [ "$expd" -eq 0 ]; then
        new_date="unlimited"
    else
        new_date=$(date -d "+${expd} days" +%Y-%m-%d)
    fi
    sed -i "s/^$pwd|.*/$pwd|$new_date/" "$EXPIRED_DB"
    echo -e "${GREEN}Renew success!!${NC}"
}

show() {
    clear
    garis
    echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP MEMBER!°            \E[0m|"
    garis

    mapfile -t passwords < <(list_accounts)
    if [ ${#passwords[@]} -eq 0 ]; then
        echo "Tidak ada akun."
    else
        get_ip_info
        domain=$(get_domain)
        for pwd in "${passwords[@]}"; do
            exp_date=$(grep "^$pwd|" "$EXPIRED_DB" | cut -d'|' -f2)
            [ -z "$exp_date" ] && exp_date="unlimited"
            [ "$exp_date" = "unlimited" ] && exp_show="UNLIMITED" || exp_show="$exp_date"

            echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "${GREEN}PREMIUM ACCOUNT ZIV UDP${NC}"
            echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "Password   : $pwd"
            echo -e "CITY       : $city"
            echo -e "ISP        : $isp"
            echo -e "Domain     : $domain"
            echo -e "Expired On : $exp_show"
            echo -e "${CY}━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo ""
        done
    fi
    garis
    echo -e "${GREEN}| \E[44;1;39m      XD STORE            \E[0m|"
    garis
}

remove_all() {
    clear
    garis
    echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP REMOVE ALL°            \E[0m|"
    garis
    read -p "Apakah Anda ingin menghapus SEMUA user? (Y/N): " choice
    if [[ "$choice" =~ ^[Yy] ]]; then
        echo "MENGHAPUS SEMUA USER!"
        for p in $(list_accounts); do
            del_account "$p"
        done
        > "$EXPIRED_DB"
        systemctl restart zivpn >/dev/null 2>&1
        echo -e "${GREEN}Semua akun berhasil dihapus!${NC}"
    else
        echo "Dibatalkan."
    fi
    garis
    echo -e "${GREEN}| \E[44;1;39m      XD STORE            \E[0m|"
    garis
}

# ==================== MAIN MENU ====================
clear
garis
echo -e "${GREEN}| \E[44;1;39m      °ZIVPN UDP SERVICE°            \E[0m|"
garis
echo -e "01. CREATE ACCOUNT ZIV UDP"
echo -e "02. DELETE ACCOUNT ZIV UDP"
echo -e "03. RENEW ACCOUNT ZIV UDP"
echo -e "04. SHOW ALL ACCOUNT ZIV UDP"
echo -e "05. REMOVE ALL ACCOUNT ZIV UDP"
echo -e "00. EXIT"
garis
echo -e "${GREEN}| \E[44;1;39m            XD STORE            \E[0m|"
garis
read -p " Select menu : " opt
case $opt in
    01|1) create ;;
    02|2) delete ;;
    03|3) renew ;;
    04|4) show ;;
    05|5) remove_all ;;
    00|0) clear; exit 0 ;;
    *) clear; echo -e "${RED}Pilihan tidak valid!${NC}" ;;
esac